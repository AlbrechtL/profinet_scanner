FROM debian:bookworm-slim

ARG PROFIPP_REPO_URL=https://github.com/langmo/profipp.git
ARG PROFIPP_REF=master

RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
    build-essential \
    ca-certificates \
    cmake \
    git \
    iproute2 \
    libsnmp-dev \
    pkg-config && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

COPY test /workspace/test

RUN git clone "${PROFIPP_REPO_URL}" /tmp/profipp && \
    cd /tmp/profipp && \
    git checkout "${PROFIPP_REF}"

RUN cmake -S /tmp/profipp -B /tmp/profipp-build \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr/local \
        -DPNET_MAX_PHYSICAL_PORTS=4 && \
    cmake --build /tmp/profipp-build --parallel && \
    cmake --install /tmp/profipp-build

RUN cmake -S /workspace/test/virtual_device -B /tmp/virtual-device-build \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_PREFIX_PATH=/usr/local && \
    cmake --build /tmp/virtual-device-build --parallel && \
    cmake --install /tmp/virtual-device-build

RUN printf '#!/bin/sh\nexit 0\n' > /usr/local/bin/set_profinet_leds \
    && chmod +x /usr/local/bin/set_profinet_leds

RUN printf '%s\n' \
    '#!/bin/sh' \
    'set -eu' \
    'mkdir -p /var/lib/pn-device' \
    'exec /usr/local/bin/profipp_virtual_device "$@"' \
    > /usr/local/bin/pn-device-entrypoint \
    && chmod +x /usr/local/bin/pn-device-entrypoint

WORKDIR /workspace

ENTRYPOINT ["/usr/local/bin/pn-device-entrypoint"]